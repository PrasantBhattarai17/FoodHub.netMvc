@model UserDTO
<div class="container">
<form  method="post" asp-controller="Auth" asp-action="Login">

    <h1>Log in to your account!</h1>
    <div class="container  pt-4">
        <div class="flex-column">

            <div class="form-group col-6 mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control w-75 border-1 rounded" placeholder="Username" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

          
            <div class="form-group col-6 mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control w-75  border-1 rounded" placeholder="Password" />
                <span asp-validation-for="Password" class="text-danger"></span>

            </div>

            <div class="pt-2 ">
                <button class="btn btn-dark rounded " type="submit">
                    Login
                </button>
            </div>
        </div>
    </div>
</form>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>
}
