@model List<HotelDto>

<h1 class="text-center m-3 fs-1 font-monospace">Hotels List</h1>

<table class="table table-bordered text-center align-middle">
    <thead class="border-2">
        <tr>
            <th colspan="8" class="fs-5 text-warning">All Registered Hotels</th>
        </tr>
        <tr>
            <th>Hotel Name</th>
            <th>Location</th>
            <th>Cuisines</th>
            <th>Category</th>
            <th>Cost</th>
            <th>Rating</th>
            <th>Discounts</th>
            <th class="">Actions</th> 
        </tr>
    </thead>
    <tbody class="border-2">
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.HotelName</td>
                <td>@a.Location</td>
                <td>@a.Cuisines</td>
                <td>@a.category</td>
                <td>@a.Price</td>
                <td>@a.Rating</td>
                <td>@if (@a.Discount =="0") {
                        <p class="p-1">N/A</p> }
                        else{
                            @a.Discount
                        }
                </td>
                <td class="">
                    <form method="post" asp-controller="Hotel" asp-action="EditHotel" class="d-inline-block">
                        <input type="hidden" name="id" value="@a.HotelId" />
                        <button class="btn btn-warning py-1" type="submit">Edit</button>
                    </form>
                    <form method="post" asp-controller="Hotel" asp-action="DeleteHotel" class="d-inline-block">
                        <input type="hidden" name="id" value="@a.HotelId" />
                        <button class="btn btn-danger   py-1" type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>


<div class="d-flex">

<form method="get">
    <button class="btn btn-dark text-white m-4" asp-controller="Hotel" asp-action="GotoHotelPage">Add New Hotel</button>
</form>

<form method="get">
    <button class="btn btn-dark text-white m-4" asp-controller="Others" asp-action="BackToDashboard">Back To DashBoard</button>
</form>
</div>